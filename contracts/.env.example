# Sentinel ERC-8004 deploy config (Mantle Sepolia)
# Copy to contracts/.env and fill, or export in shell before `forge script`.

# Deployer private key (also becomes Sentinel's registered agent address).
# Derive from the Erik Nordvik mnemonic with:
#   cast wallet private-key --mnemonic "$MNEMONIC"
PRIVATE_KEY=0x...

# Agent domain hosting the AgentCard metadata. Defaults to "sentinel.audit".
SENTINEL_DOMAIN=sentinel.audit

# Mantle Sepolia (chainId 5003)
RPC_URL=https://rpc.sepolia.mantle.xyz
